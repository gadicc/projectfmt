{
  "formatter": {
    "enabled": true,
    "includes": ["**", "!src/lint-only/**"],
    "indentStyle": "space",
    "indentWidth": 4
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "files": {
    "includes": ["**", "!src/generated/ignored.ts"]
  },
  "linter": {
    "enabled": true,
    "includes": ["**"],
    "rules": {
      "recommended": false,
      "style": {
        "noInferrableTypes": "on",
        "noNonNullAssertion": "on",
        "useConst": "off"
      }
    }
  },
  "assist": {
    "enabled": true,
    "includes": ["**", "!src/lint-only/**"],
    "actions": {
      "recommended": false,
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
